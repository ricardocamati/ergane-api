server.port=8080

# Copie este arquivo para application-local.properties e preencha os valores,
# OU exporte as variáveis de ambiente abaixo. NUNCA commite credenciais reais.
MONGO_URI=${MONGO_URI:mongodb://localhost:27017/ergane}

# Gere um segredo forte: openssl rand -base64 48
security.jwt.secret=${JWT_SECRET}
security.jwt.expiration-minutes=1440

app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:8081}
